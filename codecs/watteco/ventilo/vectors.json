{
  "_note": "Inputs are upstream TTN examples (Apache-2.0) plus synthetic frames; expected.data was authored against the device wire format and cross-checked by running reference/upstream-codec.js (the ORACLE). The Ventil'O reports differential pressure as a calibrated unsigned uint16 in pascals (cluster 0x8008 attr 0, divider 1) -> pressure.differential as-is; temperature as a signed int16 /100 degC (cluster 0x0402) -> air.temperature; battery as mV /1000 (cluster 0x0050 attr 6) -> battery volts. Upstream reads differential pressure as unsigned (no two's-complement); we follow the source of truth. Batch frames need per-device coding tables and the two prior reference frames, so this stateless codec rejects them rather than mis-decode.",
  "uplink": [
    {
      "description": "standard report, differential pressure 0x0018 = 24 Pa | payload:110A80080000290018",
      "input": { "bytes": [17, 10, 128, 8, 0, 0, 41, 0, 24], "fPort": 125, "recvTime": "2023-07-19T07:51:25.508306410Z" },
      "expected": { "data": { "pressure": { "differential": 24 } } },
      "source": "ttn-example"
    },
    {
      "description": "standard report, differential pressure 0x0190 = 400 Pa (synthetic)",
      "input": { "bytes": [17, 10, 128, 8, 0, 0, 41, 1, 144], "fPort": 125, "recvTime": "2023-07-19T07:51:25.508306410Z" },
      "expected": { "data": { "pressure": { "differential": 400 } } },
      "source": "synthetic"
    },
    {
      "description": "standard report, temperature 0x0B89 = 29.53 degC | payload:110A04020000290B89",
      "input": { "bytes": [17, 10, 4, 2, 0, 0, 41, 11, 137], "fPort": 125, "recvTime": "2023-07-19T07:51:31.598957793Z" },
      "expected": { "data": { "air": { "temperature": 29.53 } } },
      "source": "ttn-example"
    },
    {
      "description": "standard report, temperature 0xFEC0 = -3.20 degC (synthetic)",
      "input": { "bytes": [17, 10, 4, 2, 0, 0, 41, 254, 192], "fPort": 125, "recvTime": "2023-07-19T07:51:31.598957793Z" },
      "expected": { "data": { "air": { "temperature": -3.2 } } },
      "source": "synthetic"
    },
    {
      "description": "standard report, disposable battery 0x0E68 mV = 3.688 V | payload:110A00500006410503040E6804",
      "input": { "bytes": [17, 10, 0, 80, 0, 6, 65, 5, 3, 4, 14, 104, 4], "fPort": 125, "recvTime": "2023-07-19T07:51:25.508306410Z" },
      "expected": { "data": { "battery": 3.688 } },
      "source": "ttn-example"
    },
    {
      "description": "config report, firmware version | payload:110100000002000D0305020015E2",
      "input": { "bytes": [17, 1, 0, 0, 0, 2, 0, 13, 3, 5, 2, 0, 21, 226], "fPort": 125, "recvTime": "2023-07-19T07:51:25.508306410Z" },
      "expected": { "data": { "firmware": "3.5.2.5602" } },
      "source": "ttn-example"
    },
    {
      "description": "config report, dataup message type | payload:110180040000000800",
      "input": { "bytes": [17, 1, 128, 4, 0, 0, 0, 8, 0], "fPort": 125, "recvTime": "2023-07-19T07:51:25.508306410Z" },
      "expected": { "data": { "messageType": "unconfirmed" } },
      "source": "ttn-example"
    },
    {
      "description": "occupancy cluster 0x0406 is not present on the Ventil'O | payload:110A040600001801",
      "input": { "bytes": [17, 10, 4, 6, 0, 0, 24, 1], "fPort": 125, "recvTime": "2023-07-19T07:51:25.508306410Z" },
      "expected": { "errors": ["unrecognized Watteco cluster 1030"] },
      "source": "ttn-example"
    },
    {
      "description": "batch report cannot be decoded statelessly | payload:1002000080ad837582816e33c01db3ea91ed581ae21d31398b1d29f0f10eb11d10",
