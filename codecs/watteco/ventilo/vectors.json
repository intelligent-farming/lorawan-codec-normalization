      "expected": { "errors": ["batch report not supported"] },
      "source": "ttn-example"
    },
    {
      "description": "wrong fPort is rejected (synthetic)",
      "input": { "bytes": [17, 10, 128, 8, 0, 0, 41, 0, 24], "fPort": 2 },
      "expected": { "errors": ["unsupported fPort 2"] },
      "source": "synthetic"
