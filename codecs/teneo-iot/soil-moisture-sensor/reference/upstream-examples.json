{
  "_note": "Snapshot from TheThingsNetwork/lorawan-devices vendor/teneo-iot/soil-moisture-sensor-codec.yaml (Apache-2.0). Authoring reference only; excluded from the npm tarball.",
  "examples": [
    {
      "description": "Standard soil moisture message with temperature",
      "input": {
        "fPort": 1,
        "bytes": [
          12,
          40,
          255,
          156,
          4,
          63
        ]
      },
      "output": {
        "data": {
          "battery": 3.2,
          "charging": false,
          "moisture": 40,
          "sensorType": "moisture",
          "settingsAllowed": true,
          "temperature": -1,
          "valid": true
        }
      }
    },
    {
      "description": "Standard soil moisture message without temperature",
      "input": {
        "fPort": 1,
        "bytes": [
          12,
          40
        ]
      },
      "output": {
        "data": {
          "battery": 3.2,
          "charging": false,
          "moisture": 40,
          "sensorType": "moisture",
          "settingsAllowed": true,
          "valid": true
        }
      }
    }
  ]
}
