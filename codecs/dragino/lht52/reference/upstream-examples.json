  "examples": [
    {
      "description": "LHT52 indoor LoRaWAN Temperature & Humidity Sensor",
      "input": {
        "fPort": 5,
        "bytes": [
          11,
          136,
          1,
          0,
          37,
          0,
          1
        ]
      },
      "output": {
        "data": {
          "Bat_mV": 1,
          "Firmware_Version": "8801",
          "Freq_Band": 0,
          "Sensor_Model": 11,
          "Sub_Band": 37
        }
      },
      "normalizedOutput": {
        "data": [
          {
            "battery": 1
          }
        ]
      }
    },
    {
      "description": "Temperature & Humidity",
      "input": {
        "fPort": 2,
        "bytes": [
          8,
          205,
          2,
          32,
          127,
          255,
          1,
          97,
          205,
          78,
          221
        ]
      },
      "output": {
        "data": {
          "Ext": 1,
          "Hum_SHT": 54.4,
          "Systimestamp": 1640845021,
          "TempC_DS": 327.67,
          "TempC_SHT": 22.53
        }
      },
      "normalizedOutput": {
        "data": [
          {
            "air": {
              "location": "indoor",
              "temperature": 22.53,
              "relativeHumidity": 54.4
