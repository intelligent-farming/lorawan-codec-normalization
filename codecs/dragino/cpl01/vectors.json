{
  "uplink": [
    {
      "description": "fPort 2 real-time status, dry contact open (PIN_STATUS DISCONNECT)",
      "input": { "fPort": 2, "bytes": [1, 0, 0, 5, 0, 0, 10, 97, 142, 87, 64] },
      "expected": {
        "data": {
          "action": { "contactState": "open" },
          "alarm": false,
          "calculateFlag": 0,
          "totalPulse": 5,
          "disconnectDuration": 10,
          "time": "2021-11-12T12:00:00Z",
          "make": "dragino",
          "model": "cpl01"
        }
      },
      "source": "synthetic",
      "_note": "bytes[0]=0x01 -> bit0 set => DISCONNECT => contact open; oracle from upstream cpl01.js PIN_STATUS."
    },
    {
      "description": "fPort 2 real-time status, dry contact closed (CONNECT) with alarm",
      "input": { "fPort": 2, "bytes": [6, 0, 18, 52, 0, 0, 0, 97, 142, 87, 64] },
      "expected": {
        "data": {
          "action": { "contactState": "closed" },
          "alarm": true,
          "calculateFlag": 1,
          "totalPulse": 4660,
          "disconnectDuration": 0,
          "time": "2021-11-12T12:00:00Z",
          "make": "dragino",
          "model": "cpl01"
        }
      },
      "source": "synthetic",
      "_note": "bytes[0]=0x06 -> bit0 clear => CONNECT => closed; bit1 set => ALARM TRUE; CALCULATE_FLAG=(0x06&0xfc)>>2=1."
    },
    {
      "description": "fPort 3 datalog: newest record at top level, older record in history",
      "input": { "fPort": 3, "bytes": [1, 0, 0, 5, 0, 0, 10, 97, 142, 87, 64, 0, 0, 0, 6, 0, 0, 0, 97, 142, 88, 64] },
      "expected": {
        "data": {
          "action": { "contactState": "open" },
          "alarm": false,
          "calculateFlag": 0,
          "totalPulse": 5,
          "disconnectDuration": 10,
          "time": "2021-11-12T12:00:00Z",
          "history": [
            {
              "action": { "contactState": "closed" },
              "alarm": false,
              "calculateFlag": 0,
              "totalPulse": 6,
              "disconnectDuration": 0,
              "time": "2021-11-12T12:04:16Z"
            }
          ],
          "make": "dragino",
          "model": "cpl01"
        }
      },
      "source": "synthetic",
      "_note": "Two 11-byte records; upstream datalog() emits per-record OPEN/CLOSE; we map to action.contactState with the older record under history (each carries time)."
    },
    {
