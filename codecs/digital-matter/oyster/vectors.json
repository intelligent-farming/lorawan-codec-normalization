          "fixFailed": true,
          "cachedLatitude": -33.9367803,
          "cachedLongitude": 18.8708568
        },
        "warnings": ["fix failed"]
      },
      "source": "ttn-example",
      "_note": "Input from upstream-examples.json. Upstream nests the stale fix under `cached`; we suppress position.* on a failed fix and surface the cached coordinates as extras."
