          "speedKmph": 15,
          "fixFailed": false,
          "manDown": true,
          "position": { "latitude": 10, "longitude": 20 }
        }
      },
      "source": "synthetic",
      "_note": "Synthetic in-bounds fix; bytes built so int24 LE lat/lon*256e-7 = 10,20, heading 90, speed 15 km/h, batV 3.7, man-down set. expected.data from reference/upstream-codec.js remapped to the vocabulary."
    },
    {
