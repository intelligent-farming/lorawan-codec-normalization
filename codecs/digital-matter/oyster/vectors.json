        "fPort": 1,
        "bytes": [0, 48, 237, 236, 0, 50, 36, 69, 0, 0, 222]
      },
      "expected": {
        "data": {
          "battery": 5.55,
          "action": { "motion": { "detected": false } },
          "headingDeg": 0,
          "speedKmph": 0,
          "fixFailed": false,
          "position": { "latitude": -32, "longitude": 116 }
        }
      },
