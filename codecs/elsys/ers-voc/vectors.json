{
  "uplink": [
    {
      "description": "ERS VOC temperature, humidity, light and motion",
      "input": {
        "fPort": 1,
        "bytes": [1, 0, 226, 2, 41, 4, 0, 39, 5, 6]
      },
      "expected": {
        "data": {
          "air": {
            "temperature": 22.6,
            "relativeHumidity": 41,
            "lightIntensity": 39
          },
          "action": {
            "motion": {
              "detected": true,
              "count": 6
            }
          }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "ERS VOC with CO2, TVOC and battery voltage (VDD in mV normalized to volts)",
      "input": {
        "fPort": 1,
        "bytes": [1, 0, 215, 2, 48, 4, 0, 120, 6, 2, 100, 5, 0, 28, 0, 75, 7, 14, 16]
      },
      "expected": {
        "data": {
          "battery": 3.6,
          "tvoc": 75,
          "air": {
            "temperature": 21.5,
            "relativeHumidity": 48,
            "lightIntensity": 120,
            "co2": 612
          },
          "action": {
            "motion": {
              "detected": false,
              "count": 0
            }
          }
        }
      },
      "source": "synthetic"
    },
    {
      "description": "empty payload yields an error",
      "input": {
        "fPort": 1,
        "bytes": []
      },
      "expected": {
        "errors": ["empty payload"]
      },
      "source": "synthetic"
    }
  ],
  "downlink": []
}
