{
  "uplink": [
    {
      "description": "ERS temperature, humidity, light and motion",
      "input": {
        "fPort": 1,
        "bytes": [1, 0, 226, 2, 41, 4, 0, 39, 5, 6]
      },
      "expected": {
        "data": {
          "air": {
            "temperature": 22.6,
            "relativeHumidity": 41,
            "lightIntensity": 39
          },
          "action": {
            "motion": {
              "detected": true,
              "count": 6
            }
          }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "ERS with battery voltage (VDD) reported in mV, normalized to volts",
      "input": {
        "fPort": 1,
        "bytes": [1, 0, 215, 2, 55, 4, 0, 120, 5, 3, 7, 14, 16]
      },
      "expected": {
        "data": {
          "battery": 3.6,
          "air": {
            "temperature": 21.5,
            "relativeHumidity": 55,
            "lightIntensity": 120
          },
          "action": {
            "motion": {
              "detected": true,
              "count": 3
            }
          }
        }
      },
      "source": "synthetic"
    },
    {
      "description": "empty payload yields an error",
      "input": {
        "fPort": 1,
        "bytes": []
      },
      "expected": {
        "errors": ["empty payload"]
      },
      "source": "synthetic"
    }
  ],
  "downlink": []
}
