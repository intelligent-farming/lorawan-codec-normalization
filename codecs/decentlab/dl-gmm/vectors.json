      },
      "expected": {
        "errors": ["protocol version 1 doesn't match v2"]
      },
      "source": "synthetic"
    },
    {
      "description": "Short payload - fewer than 5 header bytes",
      "input": {
        "fPort": 1,
        "bytes": [2, 83, 43]
      },
      "expected": {
        "errors": ["payload too short"]
      },
      "source": "synthetic"
    },
    {
      "description": "Truncated sensor block - greenhouse flag set but words missing",
      "input": {
        "fPort": 1,
        "bytes": [2, 83, 43, 0, 1, 135, 38, 137, 32]
      },
      "expected": {
        "errors": ["payload too short: truncated sensor block"]
      },
      "source": "synthetic"
    }
  ],
  "downlink": []
