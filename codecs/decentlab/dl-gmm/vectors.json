        "bytes": [2, 83, 43, 0, 3, 135, 38, 137, 32, 129, 20, 130, 151, 165, 115, 128, 207, 129, 112, 11, 188]
      },
      "expected": {
        "data": {
          "photosyntheticallyActiveRadiation": 183,
          "vaporPressureDeficit": 2.07,
          "dewPoint": 3.68,
          "battery": 3.004,
          "air": {
            "temperature": 23.36,
            "relativeHumidity": 27.6,
            "co2": 663,
            "pressure": 958.7
          }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Example 2 - battery only (greenhouse block absent, flags clear bit 0)",
      "input": {
        "fPort": 1,
        "bytes": [2, 82, 133, 0, 2, 11, 188]
      },
      "expected": {
        "data": {
          "battery": 3.004
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Protocol version mismatch - first byte is not 2",
      "input": {
        "fPort": 1,
