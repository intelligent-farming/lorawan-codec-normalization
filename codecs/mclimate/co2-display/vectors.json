{
  "uplink": [
    {
      "description": "Periodic keepalive uplink (TTN example bytes)",
      "input": {
        "fPort": 2,
        "bytes": [1, 2, 103, 130, 11, 124, 147, 32, 0, 55, 0]
      },
      "expected": {
        "data": {
          "make": "mclimate",
          "model": "co2-display",
          "air": {
            "temperature": 21.5,
            "relativeHumidity": 50.78,
            "co2": 1171,
            "lightIntensity": 55
          },
          "battery": 2.94,
          "powerSourceStatus": 0,
          "action": { "motion": { "detected": false } }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Keepalive with PIR motion detected and brighter light (synthetic)",
      "input": {
        "fPort": 2,
        "bytes": [1, 3, 32, 128, 11, 184, 200, 35, 1, 44, 1]
      },
      "expected": {
        "data": {
          "make": "mclimate",
          "model": "co2-display",
          "air": {
            "temperature": 40.0,
            "relativeHumidity": 50.0,
            "co2": 1224,
            "lightIntensity": 300
          },
          "battery": 3.0,
          "powerSourceStatus": 3,
          "action": { "motion": { "detected": true } }
        }
      },
      "source": "synthetic"
    },
    {
      "description": "Non-keepalive packet type returns an error",
      "input": { "fPort": 2, "bytes": [2, 4, 1, 1] },
      "expected": { "errors": ["unsupported packet type"] },
      "source": "synthetic"
    },
    {
      "description": "Truncated keepalive payload returns an error",
      "input": { "fPort": 2, "bytes": [1, 2, 103] },
      "expected": { "errors": ["too short"] },
      "source": "synthetic"
    }
  ],
  "downlink": []
}
