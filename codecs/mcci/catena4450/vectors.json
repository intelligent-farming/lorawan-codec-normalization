{
  "uplink": [
    {
      "description": "Port 1 format 0x14 sensor report: vBat, boot, env (temp+pressure+RH), lux; no pulse/power input",
      "input": {
        "fPort": 1,
        "bytes": [20, 29, 67, 35, 17, 25, 82, 95, 151, 174, 1, 2]
      },
      "expected": {
        "data": {
          "battery": 4.196,
          "boot": 17,
          "air": {
            "temperature": 25.32,
            "pressure": 978.8,
            "relativeHumidity": 68,
            "lightIntensity": 258
          }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Port 1 unrecognized format discriminator is rejected",
      "input": {
        "fPort": 1,
        "bytes": [153, 1, 24, 0]
      },
      "expected": {
        "errors": ["unsupported uplink format"]
      },
      "source": "synthetic"
    },
    {
      "description": "Unsupported fPort is rejected",
      "input": {
        "fPort": 99,
        "bytes": [20, 29, 67, 35]
      },
      "expected": {
        "errors": ["unsupported fPort"]
      },
      "source": "synthetic"
    }
  ],
  "downlink": []
}
