{
  "uplink": [
    {
      "description": "Sensor report format 0x14: battery, boot, temp/pressure/RH, lux",
      "input": {
        "fPort": 1,
        "bytes": [20, 29, 67, 35, 17, 25, 82, 95, 151, 174, 1, 2]
      },
      "expected": {
        "data": {
          "battery": 4.196,
          "boot": 17,
          "air": {
            "temperature": 25.32,
            "pressure": 978.84,
            "relativeHumidity": 67.97,
            "lightIntensity": 258
          }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Unsupported fPort",
      "input": {
        "fPort": 42,
        "bytes": [1, 24, 0]
      },
      "expected": {
        "errors": ["unsupported fPort"]
      },
      "source": "synthetic"
    },
    {
      "description": "Empty payload",
      "input": {
        "fPort": 1,
        "bytes": []
      },
      "expected": {
        "errors": ["empty payload"]
      },
      "source": "synthetic"
    }
  ],
  "downlink": []
}
