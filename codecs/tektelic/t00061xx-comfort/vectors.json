{
  "uplink": [
    {
      "description": "Temperature & humidity uplink (climate: air.temperature + air.relativeHumidity, battery in volts)",
      "input": { "fPort": 10, "bytes": [3, 103, 1, 38, 4, 104, 51, 0, 186, 11, 209] },
      "expected": {
        "data": {
          "make": "tektelic",
          "model": "t00061xx-comfort",
          "battery": 3.025,
          "air": { "temperature": 29.4, "relativeHumidity": 25.5 }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Motion event uplink (motion: action.motion.detected)",
      "input": { "fPort": 10, "bytes": [10, 0, 255] },
      "expected": {
        "data": {
          "make": "tektelic",
          "model": "t00061xx-comfort",
          "action": { "motion": { "detected": true } }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Light detection uplink (categorical flag -> camelCase extra, NOT air.lightIntensity which is lux)",
      "input": { "fPort": 10, "bytes": [2, 0, 1] },
      "expected": {
        "data": { "make": "tektelic", "model": "t00061xx-comfort", "lightDetected": true }
      },
      "source": "ttn-example"
    },
    {
      "description": "Unsupported fPort is rejected",
      "input": { "fPort": 100, "bytes": [0, 1, 2, 3] },
      "expected": { "errors": ["unsupported fPort"] },
      "source": "synthetic"
    },
    {
      "description": "Unknown channel/type is rejected",
      "input": { "fPort": 10, "bytes": [255, 255, 0] },
      "expected": { "errors": ["unknown channel/type"] },
      "source": "synthetic"
    }
  ],
  "downlink": []
}
