          "air": { "temperature": 22.3 },
          "accelerationAlarm": 1,
          "accelerationX": 1,
          "accelerationY": -0.03,
          "accelerationZ": 0.12,
          "batteryEndOfService": true
        }
      },
      "source": "synthetic",
      "_note": "Synthetic accelerometer event; acceleration axis values reproduced from the upstream reference decoder (xaxis/yaxis/zaxis read MSB-first from the 6-byte chunk)."
    },
    {
      "description": "GPS fix (SE hemisphere, negative temperature) + battery2 cell",
      "input": {
        "fPort": 10,
        "bytes": [0, 136, 240, 189, 192, 77, 162, 146, 160, 0, 0, 0, 103, 255, 199, 2, 186, 45]
      },
      "expected": {
        "data": {
          "position": { "latitude": -12.5, "longitude": 130.25 },
          "air": { "temperature": -5.7 },
          "altitude": 0,
          "battery2": 2.95,
          "battery2EndOfService": false
        }
      },
      "source": "synthetic",
      "_note": "In-bounds southern/eastern coordinates and a negative temperature; expected values from the upstream reference decoder mapped to the normalized vocabulary."
    },
    {
      "description": "Unrecognized channel/type header",
      "input": {
        "fPort": 10,
        "bytes": [170, 187, 1]
      },
      "expected": {
        "errors": ["unrecognized channel/type"]
      },
      "source": "synthetic",
      "_note": "0xAA 0xBB is not a known ORCA header; the upstream reference returns a 'Couldn't find header' error for the same bytes."
    },
    {
      "description": "Wrong fPort (not a data uplink)",
      "input": {
        "fPort": 5,
        "bytes": [0, 0, 1]
      },
      "expected": {
        "errors": ["unsupported fPort 5"]
      },
      "source": "synthetic",
      "_note": "Upstream returns 'Wrong port: 5' for this fPort; we reject non-10 data ports."
    }
