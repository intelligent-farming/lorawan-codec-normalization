{
  "uplink": [
    {
      "description": "TTN example: acceleration alarm + temperature",
      "input": {
        "fPort": 10,
        "bytes": [0, 0, 1, 0, 103, 1, 90]
      },
      "expected": {
        "data": {
          "action": { "motion": { "detected": true } },
          "air": { "temperature": 34.6 },
          "accelerationAlarm": 1
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "GPS fix (NW hemisphere) + ground speed + temperature + battery1 + fix status",
      "input": {
        "fPort": 10,
        "bytes": [0, 136, 55, 21, 20, 200, 45, 124, 22, 1, 244, 0, 146, 0, 125, 0, 103, 0, 223, 1, 186, 50, 0, 149, 3]
      },
      "expected": {
        "data": {
          "battery": 3,
          "position": { "latitude": 45.12345, "longitude": -93.654321 },
          "air": { "temperature": 22.3 },
          "altitude": 250,
          "groundSpeed": 12.5,
          "batteryEndOfService": false,
          "gpsFixUtc": true,
          "gpsFixPosition": true
        }
      },
      "source": "synthetic",
      "_note": "In-bounds GPS coordinates; expected.data produced by mapping the upstream reference decoder (reference/upstream-codec.js) output for these synthetic bytes into the normalized vocabulary."
    },
    {
      "description": "Motion alarm + acceleration vector + battery1 end-of-service + temperature",
      "input": {
        "fPort": 10,
        "bytes": [0, 0, 1, 0, 113, 0, 120, 255, 226, 3, 232, 1, 186, 188, 0, 103, 0, 223]
      },
      "expected": {
        "data": {
          "action": { "motion": { "detected": true } },
