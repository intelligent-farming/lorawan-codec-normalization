{
  "uplink": [
    {
      "description": "cyclic Status-Info with SoMo1H moisture + SoMo1T temperature",
      "input": { "fPort": 10, "bytes": [137, 0, 2, 2, 1, 84, 12, 213, 3, 3, 0, 0, 216] },
      "expected": {
        "data": {
          "battery": 2.87,
          "frameType": "Status-Info",
          "soil": { "moisture": 84, "temperature": 21.6 },
          "soilMoistureRaw": 3285,
          "make": "elv",
          "model": "elv-lw-int1"
        }
      },
      "source": "ttn-example",
      "_note": "Upstream cyclic example: Supply_Voltage 2.87, SoMo1H_Level 84%, SoMo1T_Value 21.6 C, SoMo1H_Value raw 3285. Covers soil.moisture + soil.temperature."
    },
    {
      "description": "SoMo1T-only Status-Info with negative soil temperature",
      "input": { "fPort": 10, "bytes": [137, 0, 3, 3, 0, 255, 206] },
      "expected": {
        "data": {
          "battery": 2.87,
          "frameType": "Status-Info",
          "soil": { "temperature": -5 },
          "make": "elv",
          "model": "elv-lw-int1"
        }
      },
      "source": "synthetic",
      "_note": "0xFFCE = -50 (two's complement) * 0.1 = -5.0 C; upstream SoMo1T_Value '-5.0'. Verifies signed temperature path."
    },
    {
      "description": "SoMo1H-only Status-Info with soil moisture and raw reading",
      "input": { "fPort": 10, "bytes": [128, 0, 2, 2, 0, 50, 11, 184] },
      "expected": {
        "data": {
          "battery": 2.78,
          "frameType": "Status-Info",
          "soil": { "moisture": 50 },
          "soilMoistureRaw": 3000,
          "make": "elv",
          "model": "elv-lw-int1"
        }
      },
      "source": "synthetic",
      "_note": "Supply byte 128 -> 2.78 V; SoMo1H_Level 50%, raw 0x0BB8=3000. Verifies moisture-only path."
    },
    {
      "description": "SoMo1T Status-Info reporting the Error sentinel (no measurement)",
      "input": { "fPort": 10, "bytes": [137, 0, 3, 3, 128, 31, 64] },
      "expected": {
        "data": {
          "battery": 2.87,
          "frameType": "Status-Info",
          "soilTemperatureStatus": "Error",
          "make": "elv",
          "model": "elv-lw-int1"
        },
        "warnings": ["SoMo1T temperature: Error"]
      },
      "source": "synthetic",
      "_note": "0x1F40 = 8000 = upstream SoMo1T_Value 'Error' sentinel; emitted as status extra + warning, never as soil.temperature."
    },
    {
      "description": "button Status-Info (Device channel, digital input states)",
      "input": { "fPort": 10, "bytes": [137, 0, 0, 0, 8, 17] },
      "expected": {
        "data": {
          "battery": 2.87,
          "frameType": "Status-Info",
          "in1Level": "Hi",
          "in2Level": "Hi",
          "in1Changed": false,
          "in2Changed": false,
          "deviceEventCyclic": false,
          "deviceEventBoot": false,
          "deviceEventHeartbeat": false,
          "deviceEventButton": true,
          "make": "elv",
          "model": "elv-lw-int1"
        }
      },
      "source": "ttn-example",
      "_note": "Upstream button example: Device_Eventflags 8 (button), Device_InputStates 17 (IN1 Hi, IN2 Hi)."
    },
    {
      "description": "Device-Info frame (firmware / hardware identity)",
      "input": { "fPort": 10, "bytes": [136, 255, 0, 2, 21, 1, 0, 2, 2, 3, 1, 3] },
      "expected": {
        "data": {
          "battery": 2.86,
          "frameType": "Device-Info",
          "deviceType": "ELV-LW-INT1",
          "application": "1.0.2",
          "bootloader": "2.3.1",
          "hardware": "C",
          "make": "elv",
          "model": "elv-lw-int1"
        }
      },
      "source": "ttn-example",
      "_note": "Upstream device info example: type 0x000215 -> ELV-LW-INT1, app 1.0.2, bl 2.3.1, hw C, Supply 2.86 V."
    },
    {
      "description": "Firmware-ID-Info frame",
      "input": { "fPort": 10, "bytes": [137, 3, 0, 3] },
      "expected": {
        "data": {
          "battery": 2.87,
          "frameType": "Firmware-ID-Info",
          "firmwareId": "ELV-LW-INT1+DUS1+SoMo1",
          "make": "elv",
          "model": "elv-lw-int1"
        }
      },
      "source": "synthetic",
      "_note": "Index 3 -> ELV-LW-INT1+DUS1+SoMo1 per upstream firmwaretype table."
    },
    {
      "description": "wrong FPort is rejected",
      "input": { "fPort": 5, "bytes": [137, 0] },
      "expected": { "errors": ["unsupported FPort"] },
      "source": "synthetic",
      "_note": "Upstream only decodes port 10 (parser_error 'Wrong Port Number')."
    },
    {
      "description": "unknown frame type is rejected",
      "input": { "fPort": 10, "bytes": [137, 18, 0, 0] },
      "expected": { "errors": ["unknown frame type"] },
      "source": "synthetic",
      "_note": "0x12 is not a defined frame type; upstream sets parser_error 'Frame Type Failure'."
    }
  ],
  "downlink": []
}
