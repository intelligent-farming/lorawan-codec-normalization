{
  "uplink": [
    {
      "description": "TX T&H 600-034: temperature high alarm, 25% battery (upstream catalog example input)",
      "input": {
        "fPort": 1,
        "bytes": [0, 0, 209, 14, 10, 1, 0, 202, 1, 130, 0, 1, 0, 15]
      },
      "expected": {
        "data": {
          "make": "enless-wireless",
          "model": "tx-temp-cont2-600-034",
          "air": { "temperature": 20.2, "relativeHumidity": 38.6 },
          "batteryPercent": 25,
          "deviceId": 209,
          "sequenceCounter": 10,
          "firmwareVersion": 1,
          "messageType": "alarm",
          "alarmStatus": {
            "temperature": { "high": true, "low": false },
            "relativeHumidity": { "high": false, "low": false }
          }
        }
      },
      "source": "ttn-example",
      "_note": "Input is the upstream catalog example. expected.data authored here by normalizing the upstream EN311 (type 0x0e) decode: temperature/humidity are int16/uint16 big-endian x10; battery class 25% -> batteryPercent; alarm/state flags mapped to camelCase extras."
    },
    {
      "description": "Synthetic: nominal reading 21.5C / 55% RH, full battery, no alarms",
      "input": {
        "fPort": 1,
        "bytes": [0, 3, 232, 14, 5, 2, 0, 215, 2, 38, 0, 0, 0, 0]
      },
      "expected": {
        "data": {
          "make": "enless-wireless",
          "model": "tx-temp-cont2-600-034",
          "air": { "temperature": 21.5, "relativeHumidity": 55 },
          "batteryPercent": 100,
          "deviceId": 1000,
          "sequenceCounter": 5,
          "firmwareVersion": 2,
          "messageType": "normal",
          "alarmStatus": {
            "temperature": { "high": false, "low": false },
            "relativeHumidity": { "high": false, "low": false }
          }
        }
      },
      "source": "synthetic",
      "_note": "Synthetic in-bounds payload; expected.data computed by running reference/upstream-codec.js (EN311 branch) and normalizing its values/state/alarm fields."
    },
    {
      "description": "Synthetic: negative temperature -12.7C / 88% RH, 50% battery",
      "input": {
        "fPort": 1,
        "bytes": [0, 0, 42, 14, 200, 3, 255, 129, 3, 112, 0, 0, 0, 8]
