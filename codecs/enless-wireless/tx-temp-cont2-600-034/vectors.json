    {
      "description": "Error: unsupported device type byte (0x05 EN303, not this device)",
      "input": {
        "fPort": 1,
        "bytes": [0, 0, 209, 5, 10, 1, 0, 202, 1, 130, 0, 1, 0, 15]
      },
      "expected": {
        "errors": ["unsupported device type"]
      },
      "source": "synthetic",
      "_note": "Synthetic: byte 3 holds a different Enless device type; this codec only decodes EN311 (0x0e) and must reject other types rather than misdecode."
