          "firmwareVersion": 1,
          "messageType": "alarm",
          "alarmStatus": {
            "temperature": { "high": false, "low": false },
            "relativeHumidity": { "high": false, "low": true }
          }
        }
      },
      "source": "synthetic",
      "_note": "Synthetic in-bounds payload exercising the humidity-low alarm bit; expected.data computed from reference/upstream-codec.js."
    },
    {
