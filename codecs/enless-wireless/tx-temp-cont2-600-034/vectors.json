          "sequenceCounter": 200,
          "firmwareVersion": 3,
          "messageType": "normal",
          "alarmStatus": {
            "temperature": { "high": false, "low": false },
            "relativeHumidity": { "high": false, "low": false }
          }
        }
      },
      "source": "synthetic",
      "_note": "Synthetic in-bounds payload exercising two's-complement negative temperature; expected.data computed from reference/upstream-codec.js."
    },
    {
      "description": "Synthetic: humidity low alarm, 75% battery, alarm message",
      "input": {
        "fPort": 1,
        "bytes": [0, 255, 255, 14, 0, 1, 0, 50, 0, 120, 0, 8, 0, 5]
      },
      "expected": {
        "data": {
          "make": "enless-wireless",
          "model": "tx-temp-cont2-600-034",
          "air": { "temperature": 5, "relativeHumidity": 12 },
