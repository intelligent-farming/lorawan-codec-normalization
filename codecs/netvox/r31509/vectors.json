{
  "uplink": [
    {
      "description": "Temperature + humidity report (byte2=0x01)",
      "input": {
        "fPort": 6,
        "bytes": [1, 210, 1, 28, 8, 73, 0, 18, 10, 220, 106]
      },
      "expected": {
        "data": {
          "battery": 2.8,
          "air": {
            "temperature": 27.8,
            "relativeHumidity": 53
          }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Illuminance report (byte2=0x02)",
      "input": {
        "fPort": 6,
        "bytes": [1, 210, 2, 28, 8, 3, 57, 18, 0, 0, 0]
      },
      "expected": {
        "data": {
          "battery": 2.8,
          "air": {
            "lightIntensity": 2051
          },
          "lowTemperatureAlarm": true,
          "highTemperatureAlarm": false,
          "lowHumidityAlarm": false,
          "highHumidityAlarm": true,
          "lowIlluminanceAlarm": true,
          "highIlluminanceAlarm": true
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Startup version / device-info frame (byte2=0x00, no measurement)",
      "input": {
        "fPort": 6,
        "bytes": [1, 210, 0, 100, 2, 32, 32, 8, 17, 0, 0]
      },
      "expected": {
        "errors": ["device info frame"]
      },
      "source": "ttn-example"
    },
    {
      "description": "Function-enable / binary-sensor-state frame (byte2=0x11, config/state, no measurement)",
      "input": {
        "fPort": 6,
        "bytes": [1, 210, 17, 28, 1, 3, 57, 18, 128, 0, 0]
      },
      "expected": {
        "errors": ["function-enable"]
      },
      "source": "ttn-example"
    },
    {
      "description": "Configure report response (fPort 7, no measurement)",
      "input": {
        "fPort": 7,
        "bytes": [129, 210, 0, 0, 0, 0, 0, 0, 0, 0, 0]
      },
      "expected": {
        "errors": ["fPort 7"]
      },
      "source": "ttn-example"
    },
    {
      "description": "Read configure report response (fPort 7, no measurement)",
      "input": {
        "fPort": 7,
        "bytes": [130, 210, 3, 132, 7, 8, 1, 0, 50, 20, 100]
      },
      "expected": {
        "errors": ["no measurement"]
      },
      "source": "ttn-example"
    }
  ],
  "downlink": []
}
