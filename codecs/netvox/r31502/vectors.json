{
  "uplink": [
    {
      "description": "Temperature/humidity status report (TTN example bytes; report type 0x01)",
      "input": {
        "fPort": 6,
        "bytes": [1, 210, 1, 28, 8, 73, 0, 18, 10, 220, 106]
      },
      "expected": {
        "data": {
          "make": "netvox",
          "model": "r31502",
          "battery": 2.8,
          "air": { "temperature": 27.8, "relativeHumidity": 53 }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Illuminance status report with alarm flags (TTN example bytes; report type 0x02)",
      "input": {
        "fPort": 6,
        "bytes": [1, 210, 2, 28, 8, 3, 57, 18, 0, 0, 0]
      },
      "expected": {
        "data": {
          "make": "netvox",
          "model": "r31502",
          "battery": 2.8,
          "lowTemperatureAlarm": true,
          "highTemperatureAlarm": false,
          "lowHumidityAlarm": false,
          "highHumidityAlarm": true,
          "lowIlluminanceAlarm": true,
          "highIlluminanceAlarm": true,
          "air": { "lightIntensity": 2051 }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Startup version report carries no measurement (TTN example bytes; report type 0x00)",
      "input": {
        "fPort": 6,
        "bytes": [1, 210, 0, 100, 2, 32, 32, 8, 17, 0, 0]
      },
      "expected": { "errors": ["no measurement"] },
      "source": "ttn-example"
    },
    {
      "description": "Sensor enable/state snapshot carries no measurement (TTN example bytes; report type 0x11)",
      "input": {
        "fPort": 6,
        "bytes": [1, 210, 17, 28, 1, 3, 57, 18, 128, 0, 0]
      },
      "expected": { "errors": ["no measurement"] },
      "source": "ttn-example"
    },
    {
      "description": "Config response on fPort 7 is unsupported (TTN example bytes)",
      "input": {
        "fPort": 7,
        "bytes": [129, 210, 0, 0, 0, 0, 0, 0, 0, 0, 0]
      },
      "expected": { "errors": ["unsupported fPort"] },
      "source": "ttn-example"
    }
  ],
  "downlink": []
}
