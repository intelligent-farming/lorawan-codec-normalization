{
  "uplink": [
    {
      "description": "Status report (battery + temperature + humidity)",
      "input": {
        "fPort": 6,
        "bytes": [1, 210, 1, 28, 8, 73, 0, 18, 10, 220, 106]
      },
      "expected": {
        "data": {
          "battery": 2.8,
          "air": {
            "temperature": 27.8,
            "relativeHumidity": 53
          }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Illuminance report (battery + light intensity)",
      "input": {
        "fPort": 6,
        "bytes": [1, 210, 2, 28, 8, 3, 57, 18, 0, 0, 0]
      },
      "expected": {
        "data": {
          "battery": 2.8,
          "air": {
            "lightIntensity": 2051
          }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Startup version report (device info, no measurement)",
      "input": {
        "fPort": 6,
        "bytes": [1, 210, 0, 100, 2, 32, 32, 8, 17, 0, 0]
      },
      "expected": {
        "errors": ["device info frame"]
      },
      "source": "ttn-example"
    },
    {
      "description": "Function/sensor-enable + binary-state frame (no measurement)",
      "input": {
        "fPort": 6,
        "bytes": [1, 210, 17, 28, 1, 3, 57, 18, 128, 0, 0]
      },
      "expected": {
        "errors": ["binary-state flags"]
      },
      "source": "ttn-example"
    },
    {
      "description": "Configure report response on fPort 7 (no measurement)",
      "input": {
        "fPort": 7,
        "bytes": [129, 210, 0, 0, 0, 0, 0, 0, 0, 0, 0]
      },
      "expected": {
        "errors": ["fPort 7"]
      },
      "source": "ttn-example"
    }
  ],
  "downlink": []
}
