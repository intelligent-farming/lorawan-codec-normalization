{
  "uplink": [
    {
      "description": "Status report (TTN example bytes): 3.0 V, 5000 lux",
      "input": { "fPort": 6, "bytes": [1, 30, 1, 30, 0, 0, 19, 136, 0, 0, 0] },
      "expected": { "data": { "battery": 3, "air": { "lightIntensity": 5000 } } },
      "source": "ttn-example"
    },
    {
      "description": "Low-battery report with higher illuminance (synthetic): 2.8 V, 100000 lux",
      "input": { "fPort": 6, "bytes": [1, 30, 1, 156, 0, 1, 134, 160, 0, 0, 0] },
      "expected": {
        "data": { "lowBattery": true, "battery": 2.8, "air": { "lightIntensity": 100000 } }
      },
      "source": "synthetic"
    },
    {
      "description": "Startup version report (byte2 == 0) carries no measurement (TTN example bytes)",
      "input": { "fPort": 6, "bytes": [1, 30, 0, 100, 11, 32, 25, 17, 40, 0, 0] },
      "expected": { "errors": ["no measurement"] },
      "source": "ttn-example"
    },
    {
      "description": "Config response on fPort 7 is unsupported (TTN example bytes)",
      "input": { "fPort": 7, "bytes": [129, 30, 0, 0, 0, 0, 0, 0, 0, 0, 0] },
      "expected": { "errors": ["unsupported fPort"] },
      "source": "ttn-example"
    }
  ],
  "downlink": []
}
