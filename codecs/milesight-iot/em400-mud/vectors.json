        "data": {
          "batteryPercent": 80,
          "air": { "temperature": 25.0 },
          "distanceMm": 200,
          "action": { "motion": { "detected": false } }
        }
      },
      "source": "synthetic"
    },
    {
      "description": "Synthetic: abnormal-temperature and alarming-distance variants, position=tilt",
