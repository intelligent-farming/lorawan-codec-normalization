{
  "uplink": [
    {
      "description": "No leak (TTN example bytes)",
      "input": { "fPort": 85, "bytes": [1, 117, 92, 5, 0, 0] },
      "expected": { "data": { "batteryPercent": 92, "water": { "leak": false } } },
      "source": "ttn-example"
    },
    {
      "description": "Leak detected (TTN example bytes)",
      "input": { "fPort": 85, "bytes": [1, 117, 92, 5, 0, 1] },
      "expected": { "data": { "batteryPercent": 92, "water": { "leak": true } } },
      "source": "ttn-example"
    },
    {
      "description": "Datalog frame: current leak + one timestamped history point (synthetic)",
      "input": {
        "fPort": 85,
        "bytes": [1, 117, 92, 5, 0, 1, 32, 206, 242, 210, 92, 99, 0, 0, 0, 1]
      },
      "expected": {
        "data": {
          "batteryPercent": 92,
          "water": { "leak": true },
          "history": [
            { "water": { "leak": true }, "time": "2022-10-29T07:14:58.000Z" }
          ]
        }
      },
      "source": "synthetic"
    },
    {
      "description": "Unrecognized channel returns an error",
      "input": { "fPort": 85, "bytes": [255, 1] },
      "expected": { "errors": ["no recognized Milesight channels"] },
      "source": "synthetic"
    }
  ],
  "downlink": []
}
