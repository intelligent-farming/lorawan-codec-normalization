{
  "uplink": [
    {
      "description": "Battery, temperature, humidity and PIR activity (TTN example 1)",
      "input": {
        "fPort": 85,
        "bytes": [1, 117, 92, 3, 103, 52, 1, 4, 104, 101, 5, 106, 73, 0]
      },
      "expected": {
        "data": {
          "batteryPercent": 92,
          "air": {
            "temperature": 30.8,
            "relativeHumidity": 50.5
          },
          "action": {
            "motion": {
              "count": 73,
              "detected": true
            }
          }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Light channel: illuminance plus raw spectral counts (TTN example 2)",
      "input": {
        "fPort": 85,
        "bytes": [6, 101, 28, 0, 121, 0, 20, 0]
      },
      "expected": {
        "data": {
          "infraredAndVisible": 121,
          "infrared": 20,
          "air": {
            "lightIntensity": 28
          }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Unrecognized channel/type yields an error",
      "input": {
        "fPort": 85,
        "bytes": [2, 2]
      },
      "expected": {
        "errors": ["no recognized Milesight channels"]
      },
      "source": "synthetic"
    }
  ],
  "downlink": []
}
