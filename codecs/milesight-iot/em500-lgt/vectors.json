    {
      "description": "Higher battery, same illuminance (TTN example 2)",
      "input": { "fPort": 85, "bytes": [1, 117, 100, 3, 148, 80, 0, 0, 0] },
      "expected": { "data": { "make": "milesight-iot", "model": "em500-lgt", "batteryPercent": 100, "air": { "lightIntensity": 80 } } },
      "source": "ttn-example"
    },
    {
      "description": "Large illuminance value (synthetic, exercises uint32 LE)",
