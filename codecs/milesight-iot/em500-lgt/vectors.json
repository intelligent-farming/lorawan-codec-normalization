      "expected": { "data": { "make": "milesight-iot", "model": "em500-lgt", "batteryPercent": 88, "air": { "lightIntensity": 100000 } } },
      "source": "synthetic"
    },
    {
      "description": "Unrecognized channel returns an error",
      "input": { "fPort": 85, "bytes": [255, 1] },
