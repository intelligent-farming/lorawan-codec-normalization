{
  "_note": "Synthetic vectors authored for the normalized codec. Inputs are valid Milesight VS373 channel/type TLV frames (the combined detection+region frame is the upstream vs373-codec.yaml example); expected.data is authored to the normalized vocabulary, NOT copied from upstream output. action.motion.detected is true whenever the detection target status is anything other than 'vacant'; action.motion.count is the number of occupied regions. Verified against reference/upstream-codec.js wire format via the oracle method.",
  "uplink": [
    {
      "description": "v1.0.1 detection target (vacant) + region occupancy (2 of 4 occupied)",
      "input": {
        "fPort": 85,
        "bytes": [3, 248, 1, 0, 16, 0, 32, 0, 4, 249, 1, 0, 1, 0]
      },
      "expected": {
        "data": {
          "make": "milesight-iot",
          "model": "vs373",
          "detectionStatus": "vacant",
          "targetStatus": "normal",
          "useTimeNow": 16,
          "useTimeToday": 32,
          "region1Occupancy": "vacant",
          "region2Occupancy": "occupied",
          "region3Occupancy": "vacant",
          "region4Occupancy": "occupied",
          "action": {
            "motion": {
              "detected": false,
              "count": 2
            }
          }
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "v1.0.1 detection target reporting a fall (target present -> motion detected)",
      "input": {
        "fPort": 85,
        "bytes": [3, 248, 4, 0, 0, 0, 0, 0]
      },
      "expected": {
        "data": {
          "make": "milesight-iot",
          "model": "vs373",
          "detectionStatus": "fall",
          "targetStatus": "normal",
          "useTimeNow": 0,
          "useTimeToday": 0,
          "action": {
            "motion": {
              "detected": true
            }
          }
        }
      },
      "source": "synthetic"
    },
    {
      "description": "v1.0.2 detection target (in_bed, motionless) with 24-bit usage timers",
