{
  "uplink": [
    {
      "description": "Battery 100%, occupied, illuminance dim (TTN example)",
      "input": {
        "fPort": 85,
        "bytes": [1, 117, 100, 3, 0, 1, 4, 0, 0]
      },
      "expected": {
        "data": {
          "make": "milesight-iot",
          "model": "vs370",
          "batteryPercent": 100,
          "action": { "motion": { "detected": true } },
          "illuminanceLevel": "dim"
        }
      },
      "source": "ttn-example"
    },
    {
      "description": "Vacant, illuminance bright",
      "input": {
        "fPort": 85,
        "bytes": [3, 0, 0, 4, 0, 1]
      },
      "expected": {
        "data": {
          "make": "milesight-iot",
          "model": "vs370",
          "action": { "motion": { "detected": false } },
          "illuminanceLevel": "bright"
        }
      },
      "source": "synthetic"
    },
    {
      "description": "Battery only",
      "input": {
        "fPort": 85,
        "bytes": [1, 117, 88]
      },
      "expected": {
        "data": {
          "make": "milesight-iot",
          "model": "vs370",
          "batteryPercent": 88
        }
      },
      "source": "synthetic"
    },
    {
      "description": "Empty payload yields an error",
      "input": {
        "fPort": 85,
        "bytes": []
      },
      "expected": {
        "errors": ["empty payload"]
      },
      "source": "synthetic"
    },
    {
      "description": "Unrecognized leading channel yields an error",
      "input": {
        "fPort": 85,
        "bytes": [170, 187]
      },
      "expected": {
        "errors": ["no recognized Milesight channels"]
      },
      "source": "synthetic"
    }
  ],
  "downlink": []
}
