    },
    {
      "description": "Unrecognized channel/type -> error",
      "input": {
        "fPort": 85,
        "bytes": [200, 200, 1]
      },
      "expected": {
        "errors": ["no recognized Milesight channels"]
      },
      "source": "synthetic"
    },
    {
      "description": "Empty payload -> error",
      "input": {
        "fPort": 85,
        "bytes": []
      },
      "expected": {
        "errors": ["empty payload"]
      },
      "source": "synthetic"
    }
  ],
  "downlink": []
}
