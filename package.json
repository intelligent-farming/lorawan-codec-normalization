{
  "name": "@intelligent-farming/lorawan-codec-normalization",
  "version": "0.1.1",
  "description": "Curated, standalone normalized LoRaWAN payload codecs for agriculture sensors, grouped by device category so every codec in a category emits the same shared keys.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/intelligent-farming/lorawan-codec-normalization.git"
  },
  "homepage": "https://github.com/intelligent-farming/lorawan-codec-normalization#readme",
  "bugs": {
    "url": "https://github.com/intelligent-farming/lorawan-codec-normalization/issues"
  },
  "files": ["dist/", "definitions/", "codecs/", "!codecs/**/reference"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsc && node scripts/compute-provides.js",
    "provides": "node scripts/compute-provides.js",
    "provides:check": "node scripts/compute-provides.js --check",
    "scaffold": "node scripts/scaffold-device.js",
    "test": "npm run build && node --test --test-reporter=spec test/smoke.js test/conformance.js",
    "docs": "typedoc && mv docs/README.md docs/api-doc.md"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.4.0"
  },
  "peerDependencies": {
    "@intelligent-farming/ttn-to-chirpstack": "^0.1.3"
  },
  "peerDependenciesMeta": {
    "@intelligent-farming/ttn-to-chirpstack": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
